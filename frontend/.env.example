# Public frontend variables for Vercel.

# Your Render backend base URL.
# Use the root URL only. Do not add a trailing slash and do not add /api/v1.
VITE_API_BASE_URL=https://your-backend-service.onrender.com
# Optional API prefix. Defaults to /api/v1.
VITE_API_PREFIX=/api/v1

# Public Supabase browser credentials.
# Get both from Supabase Dashboard > Project Settings > API.
# VITE_SUPABASE_URL = Project URL
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
# VITE_SUPABASE_ANON_KEY = anon/public key
VITE_SUPABASE_ANON_KEY=your-supabase-anon-key
