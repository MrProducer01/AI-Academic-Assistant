# FastAPI app settings
PROJECT_NAME=AI Academic Assistant API
API_V1_PREFIX=/api/v1

# Allowed frontend origins for CORS.
# Add your local Vite URL and your deployed Vercel frontend URL, comma-separated.
BACKEND_CORS_ORIGINS=http://localhost:5173,https://your-vercel-project.vercel.app
# Optional regex to allow preview branches (for example:
# ^https://your-vercel-project(?:-[a-zA-Z0-9-]+)?\\.vercel\\.app$).
# Leave empty to auto-derive a Vercel pattern from BACKEND_CORS_ORIGINS when possible.
BACKEND_CORS_ORIGIN_REGEX=

# Supabase server-side credentials.
# Get both from Supabase Dashboard > Project Settings > API.
# SUPABASE_URL = Project URL
SUPABASE_URL=https://your-project-ref.supabase.co
# SUPABASE_SERVICE_ROLE_KEY = service_role key
# Keep this only on the backend/Render. Never put it in Vercel.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# Supabase table names used by the backend.
SUPABASE_INTERACTIONS_TABLE=interactions
SUPABASE_STUDENTS_TABLE=students

# Gemini / Google AI Studio server-side key.
# Get this from Google AI Studio.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-1.5-flash

# Render runtime pin. runtime.txt already pins this too.
PYTHON_VERSION=3.11.9
